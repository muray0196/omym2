{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "symphony: run",
            "type": "shell",
            "command": "/usr/bin/zsh",
            "args": [
                "-lc",
                "'${workspaceFolder}/.vscode/run-symphony.zsh'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false,
                "focus": false,
                "showReuseMessage": false
            },
            "problemMatcher": [],
        }
    ]
}